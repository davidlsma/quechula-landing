---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.png';
---

<section id="hero" class="hero-section">

  <!-- Fondo -->
  <Image
    src={heroBg}
    alt=""
    loading="eager"
    class="hero-bg"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
  />

  <!-- Efecto luz blanca -->
  <div class="hero-glow"></div>

  <!-- Contenido -->
  <div class="hero-content">
    <div class="hero-inner">
      <a href="/" class="hero-logo" style="text-decoration:none;">
        <span class="hero-logo-name">Qué Chula!</span>
        <span class="hero-logo-row">
          <span class="hero-logo-line"></span>
          <span class="hero-logo-sub">Peluquería</span>
          <span class="hero-logo-line"></span>
        </span>
      </a>
    </div>
  </div>

</section>

<style>
  .hero-section {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    object-position: 100% 5%;
  }

  @media (max-width: 640px) {
    .hero-bg {
      object-position: 65% 5%;
    }
  }

  /* ── Luz blanca ── */
  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse 60% 70% at 25% 40%, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0) 70%);
    pointer-events: none;
  }

  /* ── Contenido ── */
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    padding-left: clamp(8rem, 18vw, 22rem);
    padding-right: 2rem;
    max-width: 52%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (max-width: 640px) {
    .hero-inner {
      max-width: 100%;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      align-items: center;
    }
    .hero-glow { display: none; }
  }

  .hero-logo {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    line-height: 1;
    background-color: #000;
    padding: 0.6rem 1.5rem;
    border: 2px solid #fff;
    border-radius: 14px;
    margin-bottom: 1.5rem;
  }
  .hero-logo-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.5rem;
    text-transform: uppercase;
    color: #fff;
    letter-spacing: 0.06em;
    -webkit-text-stroke: 2px #000;
    paint-order: stroke fill;
  }
  .hero-logo-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .hero-logo-line {
    flex: 1;
    height: 1px;
    background-color: #fff;
    opacity: 0.45;
  }
  .hero-logo-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #fff;
    opacity: 0.7;
    white-space: nowrap;
  }

  .hero-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    -webkit-text-stroke: 2px var(--color-primary);
    paint-order: stroke fill;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 1rem;
    line-height: 1.05;
  }
  .hero-title-line1 {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 6.5rem);
    color: #fff;
    -webkit-text-stroke: 7px var(--color-primary);
    paint-order: stroke fill;
    letter-spacing: -0.01em;
  }
  .hero-title-line2 {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 6.5rem);
    color: #fff;
    -webkit-text-stroke: 7px var(--color-primary);
    paint-order: stroke fill;
    letter-spacing: -0.01em;
  }

  .hero-divider {
    width: 3rem;
    height: 3px;
    background-color: var(--color-primary);
    border-radius: 999px;
    margin-bottom: 2rem;
  }

  .hero-cta {
    background-color: var(--color-primary);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    border-radius: 999px;
    display: inline-block;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .hero-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }
</style>
