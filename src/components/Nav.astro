---
const navLinks = [
  { href: '/#nosotros',   label: 'Historia'  },
  { href: '/#servicios',  label: 'Servicios' },
  { href: '/#galeria',    label: 'Galería'   },
  { href: '/#contacto',   label: 'Turnos'    },
  { href: '/#ubicacion',  label: 'Ubicación' },
];
const IG = 'https://www.instagram.com/quechulapeluqueria';
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50">
  <div class="wrap">
    <nav class="nav-inner">

      <a href="/" aria-label="Inicio" class="nav-logo" style="text-decoration:none;">
        <span class="nav-logo-name">Qué Chula!</span>
        <span class="nav-logo-row">
          <span class="nav-logo-line"></span>
          <span class="nav-logo-sub">Peluquería</span>
          <span class="nav-logo-line"></span>
        </span>
      </a>

      <!-- Links desktop -->
      <ul class="nav-links">
        {navLinks.map((link, i) => (
          <li class="nav-item">
            {i > 0 && <span class="nav-sep">|</span>}
            <a href={link.href} class="nav-link">{link.label}</a>
          </li>
        ))}
      </ul>

      <!-- Botón hamburguesa (solo mobile) -->
      <button id="nav-hamburger" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

    </nav>
  </div>

  <!-- Menú desplegable mobile -->
  <div id="nav-mobile-menu">
    <ul>
      {navLinks.map(link => (
        <li><a href={link.href} class="nav-mobile-link">{link.label}</a></li>
      ))}
      <li><a href={IG} target="_blank" rel="noopener noreferrer" class="nav-mobile-link">Instagram</a></li>
    </ul>
  </div>
</header>

<script>
  const nav       = document.getElementById('main-nav');
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('nav-mobile-menu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 80);
  }, { passive: true });

  hamburger?.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    hamburger.classList.toggle('open', !open);
    mobileMenu?.classList.toggle('open', !open);
  });

  // Cerrar al hacer click en un link
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.classList.remove('open');
      mobileMenu.classList.remove('open');
    });
  });
</script>

<style>
  #main-nav {
    background-color: #000;
    opacity: 0;
    pointer-events: none;
    transition: background-color 0.3s ease, opacity 0.3s ease;
    z-index: 100;
  }
  #main-nav.scrolled {
    opacity: 1;
    pointer-events: auto;
  }
  #main-nav .wrap {
    max-width: 100%;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .nav-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
    position: relative;
  }

  /* ── Logo ── */
  .nav-logo {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    line-height: 1;
  }
  .nav-logo-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2rem;
    text-transform: uppercase;
    color: #fff;
    letter-spacing: 0.06em;
    -webkit-text-stroke: 2px #000;
    paint-order: stroke fill;
  }
  .nav-logo-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .nav-logo-line {
    flex: 1;
    height: 1px;
    background-color: #fff;
    opacity: 0.45;
  }
  .nav-logo-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #fff;
    opacity: 0.7;
    white-space: nowrap;
    -webkit-text-stroke: 1px #000;
    paint-order: stroke fill;
  }

  /* ── Links desktop ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
  }
  .nav-item {
    display: flex;
    align-items: center;
  }
  .nav-sep {
    color: #1a1a1a;
    opacity: 0.4;
    margin: 0 0.75rem;
    font-size: 0.85rem;
  }
  .nav-link {
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: #1a1a1a;
    transition: color 0.2s ease;
  }
  .nav-link:hover { color: var(--color-primary); }
  #main-nav.scrolled .nav-link { color: #fff; }
  #main-nav.scrolled .nav-link:hover { color: rgba(255,255,255,0.8); }
  #main-nav.scrolled .nav-sep { color: #fff; opacity: 0.5; }

  /* ── Hamburguesa ── */
  #nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
  }
  #nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #fff;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  #nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #nav-hamburger.open span:nth-child(2) { opacity: 0; }
  #nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Menú mobile desplegable ── */
  #nav-mobile-menu {
    display: none;
    background-color: #000;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }
  #nav-mobile-menu.open {
    max-height: 400px;
  }
  #nav-mobile-menu ul {
    list-style: none;
    padding: 0.5rem 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nav-mobile-link {
    display: block;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    color: #fff;
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: color 0.2s ease;
  }
  .nav-mobile-link:hover { color: #ffadd0; }

  /* ── Mobile: ocultar links, mostrar hamburguesa ── */
  @media (max-width: 640px) {
    .nav-links { display: none; }
    #nav-hamburger { display: flex; }
    #nav-mobile-menu { display: block; }
    .nav-inner { gap: 0.5rem; }
  }
</style>
