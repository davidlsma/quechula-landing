---
---

<section id="servicios" class="services-section">
  <div class="services-wrap">

    <!-- Texto -->
    <div class="services-text">
      <h2 class="services-title">Nuestra<br /><span style="color:#ffadd0;">Especialidad</span></h2>
    </div>

    <!-- Imagen -->
    <div class="services-img-wrap">
      <img src="/servicios-img.jpg" alt="Servicios Qué Chula" class="services-img" />
    </div>

  </div>
</section>

<style>
  .services-section {
    background-color: #000;
    padding: 5rem 0;
  }

  .services-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  /* ── Imagen ── */
  .services-img-wrap {
    flex: 1;
    overflow: hidden;
  }
  .services-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Texto ── */
  .services-text {
    flex: 0 0 260px;
    padding-left: 0;
  }

  .services-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 3rem);
    text-transform: uppercase;
    color: #fff;
    letter-spacing: 0.08em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .services-sub {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    color: #fff;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .services-section { padding: 2.5rem 0; }
    .services-wrap { flex-direction: column; gap: 1rem; }
    .services-text { flex: none; width: 100%; border-left: none; border-top: none; padding-left: 0; padding-top: 0; text-align: center; }
    .services-img-wrap { flex: none; width: 100%; }
  }
</style>
