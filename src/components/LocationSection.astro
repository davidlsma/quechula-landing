---
const MAPS_URL   = 'https://maps.google.com/?q=Sta+Fe+Este+497,+San+Juan,+Argentina';
const MAPS_EMBED = 'https://maps.google.com/maps?q=Sta+Fe+Este+497,+J5402AAI+San+Juan,+Argentina&output=embed';
---

<section id="ubicacion" class="section-block" style="background-color:var(--color-surface); padding-top:3rem; padding-bottom:3rem;">
  <div class="wrap">

    <div class="fade-in" style="text-align:center; margin-bottom:2rem;">
      <h2 class="heading-xl" style="color:#ffffff;">Visitanos</h2>
    </div>

    <div class="location-grid">

      <div class="fade-in location-info">
        <div>
          <p class="label-tag" style="color:#ffadd0; margin-bottom:0.5rem;">Dirección</p>
          <p class="loc-text" style="color:#ffffff;">Sta Fe Este 497</p>
          <p class="loc-text" style="color:rgba(255,255,255,0.7);">J5402AAI, San Juan, Argentina</p>
        </div>
        <div>
          <p class="label-tag" style="color:#ffadd0; margin-bottom:0.5rem;">Horarios</p>
          <p class="loc-text" style="color:rgba(255,255,255,0.7);">Lunes a Viernes: 9:00 — 19:00</p>
          <p class="loc-text" style="color:rgba(255,255,255,0.7);">Sábados: 9:00 — 14:00</p>
        </div>
      </div>

      <div class="fade-in" style="height:320px; overflow:hidden;">
        <iframe
          src={MAPS_EMBED}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Qué Chula Peluquería"
        ></iframe>
      </div>

    </div>
  </div>
</section>

<style>
  .location-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .location-grid { grid-template-columns: 1fr 1.5fr; gap: 4rem; }
  }

  .location-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .loc-text {
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.05em;
  }
</style>
