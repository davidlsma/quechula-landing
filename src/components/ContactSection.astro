---
const WA = 'https://wa.me/542645562525?text=Hola!%20Quiero%20reservar%20un%20turno';
const IG = 'https://www.instagram.com/quechulapeluqueria';
---

<section id="contacto" class="contact-section">
  <div class="contact-inner">

    <!-- Columna izquierda: texto -->
    <div class="contact-text fade-in">
      <p class="contact-eyebrow">¿Lista para transformarte?</p>
      <h2 class="contact-title">Pedi tu<br/>turno</h2>
      <p class="contact-desc">Reservá tu lugar por WhatsApp o escribinos por Instagram. Atendemos de lunes a viernes de 9:00 a 19:00 y sábados de 9:00 a 14:00.</p>
    </div>

    <!-- Columna derecha: botones -->
    <div class="contact-ctas fade-in">
      <a href={WA} target="_blank" rel="noopener noreferrer" class="contact-btn contact-btn-wa">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>
          <strong>Reservar por WhatsApp</strong>
          <small>+54 264 556-2525</small>
        </span>
      </a>

      <a href={IG} target="_blank" rel="noopener noreferrer" class="contact-btn contact-btn-ig">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        <span>
          <strong>Seguinos en Instagram</strong>
          <small>@quechulapeluqueria</small>
        </span>
      </a>
    </div>

  </div>
</section>

<style>
  .contact-section {
    background-color: #fff;
    padding: 5rem 2rem;
  }

  .contact-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Texto ── */
  .contact-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ffadd0;
    margin-bottom: 1rem;
  }

  .contact-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ffadd0;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .contact-desc {
    font-family: 'Fredoka', sans-serif;
    font-size: 1rem;
    color: #666;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-hours {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-left: 3px solid #ffadd0;
    padding-left: 1rem;
  }
  .contact-hours-item {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }
  .contact-hours-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  .contact-hours-val {
    font-family: 'Fredoka', sans-serif;
    font-size: 0.9rem;
    color: #888;
  }

  /* ── Botones ── */
  .contact-ctas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.75rem;
    text-decoration: none;
    border: 2px solid #1a1a1a;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .contact-btn span {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .contact-btn strong {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .contact-btn small {
    font-family: 'Fredoka', sans-serif;
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .contact-btn-wa {
    background: #000;
    color: #fff;
    border-color: #000;
  }
  .contact-btn-wa:hover { background: #fff; color: #000; }

  .contact-btn-ig {
    background: #fff;
    color: #1a1a1a;
    border-color: #ffadd0;
  }
  .contact-btn-ig:hover { background: #ffadd0; color: #fff; border-color: #ffadd0; }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-section { padding: 3rem 1.5rem; }
  }
</style>
